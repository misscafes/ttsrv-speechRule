<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <View
        android:id="@+id/vw_bg"
        android:background="#90000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:themeMode="dark"/>
    <TextView
        android:textColor="@color/md_white_1000"
        android:id="@+id/tv_timer"
        android:background="@drawable/shape_fillet_btn_press"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:drawableLeftCompat="@drawable/ic_timer_black_24dp"
        app:drawableTint="@color/md_white_1000"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar"/>
    <TextView
        android:textColor="@color/md_white_1000"
        android:id="@+id/tv_speed"
        android:background="@drawable/shape_fillet_btn_press"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar"/>
    <io.legado.app.ui.widget.image.CircleImageView
        android:id="@+id/iv_cover"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/img_cover"
        app:civ_border_color="@color/accent"
        app:civ_border_width="2dp"
        app:layout_constraintBottom_toTopOf="@+id/lyricViewX"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar"/>
    <com.dirror.lyricviewx.LyricViewX
        android:id="@+id/lyricViewX"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_sub_title"
        app:layout_constraintTop_toBottomOf="@+id/iv_cover"
        app:lrcCurrentTextColor="@color/md_white_1000"
        app:lrcPadding="16dp"/>
    <TextView
        android:textColor="@color/md_white_1000"
        android:gravity="center"
        android:id="@+id/tv_sub_title"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toTopOf="@+id/ll_player_progress"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_player_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toTopOf="@+id/ll_play_menu">
        <TextView
            android:textColor="@color/md_white_1000"
            android:id="@+id/tv_dur_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"/>
        <io.legado.app.lib.theme.view.ThemeSeekBar
            android:layout_gravity="center_vertical"
            android:id="@+id/player_progress"
            android:layout_width="0dp"
            android:layout_height="25dp"
            android:layout_weight="1"
            android:progressBackgroundTint="@color/md_dark_secondary"/>
        <TextView
            android:textColor="@color/md_white_1000"
            android:id="@+id/tv_all_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_play_menu"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="6dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_timer"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_timer_black_24dp"
            android:contentDescription="@string/set_timer"
            app:tint="@color/md_white_1000"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_speed_control"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_speed_control"
            android:contentDescription="@string/speed_control"
            app:tint="@color/md_white_1000"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_skip_previous"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="@string/skip_previous"
            app:tint="@color/md_white_1000"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_play_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:src="@drawable/ic_play_24dp"
                android:tint="@color/md_black_1000"
                android:contentDescription="@string/audio_play"
                app:backgroundTint="@color/md_white_1000"
                app:elevation="2dp"
                app:fabSize="normal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:pressedTranslationZ="2dp"/>
            <io.legado.app.lib.theme.view.ThemeProgressBar
                android:id="@+id/progress_loading"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_skip_next"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="@string/skip_next"
            app:tint="@color/md_white_1000"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_play_mode"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_play_mode_list_end_stop"
            android:contentDescription="@string/play_mode"
            app:tint="@color/md_white_1000"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <io.legado.app.ui.widget.image.ImageButton
            android:id="@+id/iv_chapter"
            android:background="@drawable/selector_circle_btn_bg"
            android:padding="5dp"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_chapter_list"
            android:contentDescription="@string/chapter_list"
            app:tint="@color/md_white_1000"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
