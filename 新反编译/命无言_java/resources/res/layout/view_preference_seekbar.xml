<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingTop="10dp"
    android:paddingRight="16dp"
    android:paddingBottom="10dp"
    android:focusable="false"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="60dp">
    <LinearLayout
        android:orientation="vertical"
        android:paddingRight="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/primaryText"
            android:id="@+id/preference_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:singleLine="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/tv_text_summary"
            android:id="@+id/preference_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/default1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_seek_reduce"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_reduce"
            android:tint="@color/primaryText"
            android:contentDescription="@string/reduce"/>
        <io.legado.app.lib.theme.view.ThemeSeekBar
            android:layout_gravity="center_vertical"
            android:id="@+id/seek_bar"
            android:layout_width="0dp"
            android:layout_height="25dp"
            android:max="100"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_seek_plus"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_add"
            android:tint="@color/primaryText"
            android:contentDescription="@string/plus"/>
        <TextView
            android:textColor="@color/primaryText"
            android:gravity="right"
            android:id="@+id/tv_seek_value"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
