<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/ll_content"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/primaryText"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="2dp"
            android:minWidth="88dp"
            android:text="@string/switch_on"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="53dp"
            android:layout_height="match_parent">
            <androidx.appcompat.widget.SwitchCompat
                android:gravity="start|center_vertical"
                android:id="@+id/sr_enabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:width="20dp"
                android:layout_weight="1"
                style="@style/Widget.AppCompat.CompoundButton.Switch"/>
        </LinearLayout>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="65dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/primaryText"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="100dp"
            android:text="@string/start_from"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <EditText
            android:textSize="16sp"
            android:id="@+id/start_date"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="49dp"
            android:layout_marginRight="68dp"
            android:hint="Select date"
            android:ems="10"
            android:layout_weight="1"
            android:inputType="none"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="left"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="63dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:minWidth="100dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/primaryText"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="2dp"
                android:text="@string/start_chapter"/>
        </LinearLayout>
        <EditText
            android:textSize="14sp"
            android:textColor="@color/primaryText"
            android:layout_gravity="center"
            android:id="@+id/edit_start"
            android:background="@drawable/bg_edit"
            android:paddingLeft="5dp"
            android:paddingTop="4dp"
            android:paddingRight="5dp"
            android:paddingBottom="4dp"
            android:layout_width="47dp"
            android:layout_height="wrap_content"
            android:minWidth="60dp"
            android:hint="@string/start"
            android:lines="1"
            android:maxLength="5"
            android:inputType="number"
            android:textCursorDrawable="@drawable/shape_text_cursor"
            android:importantForAutofill="no"/>
        <LinearLayout
            android:gravity="end"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/primaryText"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="5dp"
                android:text="@string/daily_chapters"/>
            <EditText
                android:textSize="14sp"
                android:textColor="@color/primaryText"
                android:layout_gravity="center"
                android:id="@+id/edit_num"
                android:background="@drawable/bg_edit"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:paddingRight="5dp"
                android:paddingBottom="4dp"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:hint="3"
                android:lines="1"
                android:maxLength="5"
                android:inputType="number"
                android:textCursorDrawable="@drawable/shape_text_cursor"
                android:textAlignment="center"
                android:importantForAutofill="no"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
