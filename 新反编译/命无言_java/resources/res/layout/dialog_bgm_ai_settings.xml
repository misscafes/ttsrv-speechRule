<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root_view"
    android:background="@color/background_menu"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI智能切歌"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/switchAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/primaryText"
            android:gravity="center"
            android:id="@+id/btnAIProvider"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="AI提供商"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/primaryText"
            android:gravity="center"
            android:id="@+id/btnAIPrompt"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="AI提示词"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/primaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分析字数："/>
        <io.legado.app.lib.theme.view.ThemeSeekBar
            android:id="@+id/seekAIInterval"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="90"
            android:progress="25"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/primaryText"
            android:gravity="end"
            android:id="@+id/tvAIIntervalValue"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="350字"/>
    </LinearLayout>
</LinearLayout>
