<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:padding="16.0dp" android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="16.0sp" android:textStyle="bold" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12.0dp" android:text="编辑配置" />
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="显示名称" />
        <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:id="@id/et_display_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" android:hint="请输入配置名称" />
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="所属分组" />
        <Spinner android:id="@id/spinner_group" android:background="@drawable/bg_spinner" android:padding="8.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="选择音色分类" />
        <Spinner android:id="@id/spinner_category" android:background="@drawable/bg_spinner" android:padding="8.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="选择发音人" />
        <Spinner android:id="@id/spinner_voice" android:background="@drawable/bg_spinner" android:padding="8.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="试听" />
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp">
            <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:id="@id/et_preview_text" android:layout_width="0.0dp" android:layout_height="wrap_content" android:text="你好，这是一段试听语音" android:hint="输入试听文本" android:layout_weight="1.0" />
            <Button android:id="@id/btn_preview" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="试听" android:layout_marginStart="8.0dp" />
        </LinearLayout>
        <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="选择标签" />
        <Spinner android:id="@id/spinner_tag" android:background="@drawable/bg_spinner" android:padding="8.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
        <LinearLayout android:orientation="vertical" android:id="@id/ll_preset" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="选择高级音色预设提示词" />
            <Spinner android:id="@id/spinner_preset" android:background="@drawable/bg_spinner" android:padding="8.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
            <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="语音提示词（仅高级音色支持）" />
            <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:gravity="top" android:id="@id/et_prompt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" android:minLines="4" />
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:id="@id/ll_emotion" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="情绪选择（仅情感音色支持）" />
            <LinearLayout android:orientation="vertical" android:id="@id/ll_emotion_check" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0dp" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0" android:layout_marginEnd="4.0dp">
                <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="采样率" />
                <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:id="@id/et_sample_rate" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_marginLeft="4.0dp" android:layout_marginRight="4.0dp" android:layout_weight="1.0" android:layout_marginHorizontal="4.0dp">
                <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="语速" />
                <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:id="@id/et_speed" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0" android:layout_marginStart="4.0dp">
                <TextView android:textSize="13.0sp" android:textColor="@color/primaryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="音量" />
                <EditText android:textSize="14.0sp" android:textColor="@color/primaryText" android:id="@id/et_volume" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
