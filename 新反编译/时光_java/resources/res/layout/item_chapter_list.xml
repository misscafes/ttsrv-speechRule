<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/tv_chapter_item"
    android:background="?attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">
    <LinearLayout
        android:gravity="center"
        android:id="@+id/ll_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_locked"
            android:padding="4dp"
            android:visibility="visible"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_lock_outline"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/iv_volume"
            android:visibility="visible"
            android:clickable="false"
            android:layout_width="18dp"
            android:layout_height="26dp"
            android:checkable="true"
            android:layout_marginEnd="8dp"
            app:icon="@drawable/m3_split_button_chevron_avd"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="16dp"
            style="@style/Widget.Material3Expressive.Button.TonalButton"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_chap"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_checked"
        app:layout_constraintStart_toEndOf="@+id/ll_info"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:id="@+id/tv_chapter_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            app:layout_constraintEnd_toStartOf="@+id/iv_checked"
            app:layout_constraintStart_toEndOf="@+id/iv_locked"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="12sp"
            android:id="@+id/tv_word_count"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:paddingEnd="18dp"
            app:layout_constraintEnd_toStartOf="@+id/iv_checked"
            app:layout_constraintStart_toEndOf="@+id/iv_locked"
            app:layout_constraintTop_toBottomOf="@+id/tv_chapter_name"/>
        <TextView
            android:textSize="12sp"
            android:id="@+id/tv_tag"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            app:layout_constraintEnd_toStartOf="@+id/iv_checked"
            app:layout_constraintStart_toEndOf="@+id/iv_locked"
            app:layout_constraintTop_toBottomOf="@+id/tv_word_count"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/iv_checked"
        android:padding="4dp"
        android:visibility="invisible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_check"
        android:contentDescription="@string/success"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorSecondary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
