<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:paddingVertical="16dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/iv_award"
                android:clickable="false"
                android:layout_width="48dp"
                android:layout_height="56dp"
                app:icon="@drawable/ic_award"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="32dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/Widget.Material3Expressive.Button.TonalButton"/>
            <TextView
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="bottom"
                android:id="@+id/bottom_sheet_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/update_available"
                android:includeFontPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_award"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_download"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                style="@style/Widget.Material3Expressive.Button.IconButton.Tonal"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="bottom"
        android:orientation="horizontal"
        android:id="@+id/ll_current"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="4dp">
        <TextView
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textSize="16sp"
            android:textStyle="bold"
            android:id="@+id/tv_current_version"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/text"
            android:layout_weight="1"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="8dp"
            app:strokeWidth="0dp">
            <TextView
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:id="@+id/tv_abi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/abi_arm64_v8a"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <View
        android:background="?attr/colorPrimaryContainer"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginVertical="4dp"/>
    <LinearLayout
        android:gravity="bottom"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:id="@+id/tv_version"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/text"
            android:maxLines="1"
            android:layout_weight="1"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorTertiaryContainer"
            app:cardCornerRadius="8dp"
            app:strokeWidth="0dp">
            <TextView
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textStyle="bold"
                android:textColor="?attr/colorTertiary"
                android:id="@+id/tv_variable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <TextView
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorPrimary"
        android:autoLink="web"
        android:id="@+id/tv_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/download_link"
        android:paddingVertical="8dp"/>
    <TextView
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update_log"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <io.legado.app.ui.widget.text.ScrollTextView
                android:id="@+id/text_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textIsSelectable="true"
                android:paddingVertical="8dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
