<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root_view"
    android:background="?attr/colorSurface"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:id="@+id/tv_title"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="音效设置"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">
        <TextView
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="音效模式"
            android:layout_weight="1"/>
        <Spinner
            android:id="@+id/spinner_sound_effect"
            android:layout_width="140dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">
        <TextView
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="偏移字数"
            android:layout_weight="1"/>
        <EditText
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            android:gravity="end"
            android:id="@+id/et_sound_effect_offset"
            android:background="@drawable/bg_listen_section_card"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="5"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/tv_sound_effect_vol_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="音效音量"
                android:layout_weight="1"/>
            <TextView
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:gravity="end"
                android:id="@+id/tv_sound_effect_volume_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="80%"/>
        </LinearLayout>
        <io.legado.app.lib.theme.view.ThemeSlider
            android:id="@+id/seek_sound_effect_volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:stepSize="1"
            android:valueFrom="0"
            android:valueTo="100"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">
        <TextView
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="规则下载"
            android:layout_weight="1"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/btn_download_rules"
            android:background="@drawable/bg_listen_section_card"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:paddingHorizontal="16dp">
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下载规则"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:id="@+id/tv_download_status"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
