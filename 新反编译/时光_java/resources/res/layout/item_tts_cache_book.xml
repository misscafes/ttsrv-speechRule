<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingVertical="8dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:id="@+id/tv_book_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_weight="1"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="12sp"
            android:textColor="?attr/colorError"
            android:id="@+id/btn_clear_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="删除"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="0dp"
            style="@style/Widget.Material3.Button.TextButton"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="?attr/colorPrimary"
        android:id="@+id/tv_chapter_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp">
        <TextView
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/tv_file_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/tv_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton
        android:textSize="12sp"
        android:id="@+id/btn_expand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="展开章节详情 ▾"
        style="@style/Widget.Material3.Button.TonalButton"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/chapter_action_bar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">
        <com.google.android.material.button.MaterialButton
            android:textSize="11sp"
            android:id="@+id/btn_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="全选"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="0dp"
            style="@style/Widget.Material3.Button.TextButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="11sp"
            android:textColor="?attr/colorError"
            android:id="@+id/btn_delete_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="删除选中"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="0dp"
            style="@style/Widget.Material3.Button.TextButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="11sp"
            android:textColor="?attr/colorPrimary"
            android:id="@+id/btn_merge_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="合并选中"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="0dp"
            style="@style/Widget.Material3.Button.TextButton"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/chapter_container"
        android:background="?attr/colorSurfaceContainerLow"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingVertical="2dp"/>
</LinearLayout>
