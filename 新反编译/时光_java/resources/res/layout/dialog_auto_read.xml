<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp">
    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        android:paddingVertical="16dp"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/ll_tts_SpeechRate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tv_read_speed_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_page_speed"
            style="@style/ChapterNameText"/>
        <TextView
            android:textSize="16sp"
            android:id="@+id/tv_read_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <com.google.android.material.slider.Slider
        android:id="@+id/seek_auto_read"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1"
        android:valueFrom="1"
        android:valueTo="120"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.google.android.material.button.MaterialButton
                android:textSize="12sp"
                android:id="@+id/btn_catalog"
                android:padding="0dp"
                android:layout_width="64dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_toc"
                app:iconGravity="textTop"
                app:iconPadding="4dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Tonal"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chapter_list"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.google.android.material.button.MaterialButton
                android:textSize="12sp"
                android:id="@+id/btn_main_menu"
                android:padding="0dp"
                android:layout_width="64dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_menu"
                app:iconGravity="textTop"
                app:iconPadding="4dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Tonal"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/main_menu"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_auto_page_stop"
                android:padding="0dp"
                android:layout_width="64dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_auto_page_stop"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Tonal"/>
            <TextView
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stop"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_setting"
                android:padding="0dp"
                android:layout_width="64dp"
                android:layout_height="48dp"
                android:text=""
                app:icon="@drawable/ic_settings"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Tonal"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setting"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
